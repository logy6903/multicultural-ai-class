# ============================================================
# AI 다문화 동료 협력학습 — 환경 변수 템플릿
# 사용법: cp .env.example .env.local 후 실제 값 입력
# .env.local 은 .gitignore 로 차단되어 안전합니다
# ============================================================

# ── Supabase (필수) ───────────────────────────────
# https://supabase.com/dashboard → 본 프로젝트 → API Keys / Data API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI ───────────────────────────────
# 미설정 시 폴백 예시 메시지로 동작
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── 서버 ───────────────────────────────
PORT=13000
NODE_ENV=development
